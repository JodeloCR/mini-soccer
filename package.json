{
  "name": "mini-soccer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Huateque CR - 3D top-down 1v1 mini soccer for two phones via QR",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "server:dev": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke": "node scripts/shot.mjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "three": "^0.169.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/qrcode": "^1.5.5",
    "@types/three": "^0.169.0",
    "@types/ws": "^8.5.12",
    "puppeteer": "^25.2.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1"
  }
}
